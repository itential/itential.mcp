# Managed by Ansible — itential.mcp role
# Do not edit this file manually. Changes will be overwritten on the next run.
# Platform credentials — kept separate from mcp.conf so non-sensitive config
# can be reviewed without exposing secrets.
{% if mcp_platform_client_id %}
ITENTIAL_MCP_PLATFORM_CLIENT_ID={{ mcp_platform_client_id }}
ITENTIAL_MCP_PLATFORM_CLIENT_SECRET={{ mcp_platform_client_secret }}
{% else %}
ITENTIAL_MCP_PLATFORM_USER={{ mcp_platform_user }}
ITENTIAL_MCP_PLATFORM_PASSWORD={{ mcp_platform_password }}
{% endif %}
ITENTIAL_MCP_CONFIG={{ mcp_conf_file }}
{% if mcp_platform_ca_bundle %}
SSL_CERT_FILE={{ mcp_platform_ca_bundle }}
{% endif %}
