# Managed by Ansible — itential.mcp role
# Do not edit this file manually. Changes will be overwritten on the next run.

[server]
transport = {{ mcp_transport }}
{% if mcp_transport in ['sse', 'http'] %}
host = {{ mcp_host }}
port = {{ mcp_port }}
{% endif %}
log_level = {{ mcp_log_level }}
response_format = {{ mcp_response_format }}
keepalive_interval = {{ mcp_keepalive_interval }}
{% if mcp_include_tags %}
include_tags = {{ mcp_include_tags }}
{% endif %}
{% if mcp_exclude_tags %}
exclude_tags = {{ mcp_exclude_tags }}
{% endif %}

[platform]
host = {{ mcp_platform_host }}
{% if mcp_platform_port | int != 0 %}
port = {{ mcp_platform_port }}
{% endif %}
disable_tls = {{ (not mcp_platform_tls | bool) | lower }}
disable_verify = {{ mcp_platform_disable_verify | lower }}
timeout = {{ mcp_platform_timeout }}
